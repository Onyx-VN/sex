<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/purple_700"
    tools:context=".MainActivity">

    <!-- Header Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Description -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bảng điều khiển chức năng"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- ScrollView for buttons -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Attack Button -->
            <Button
                android:id="@+id/btn_attack"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="⚔️ Tấn công"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_attack_background"
                android:layout_marginBottom="12dp"
                android:stateListAnimator="@null" />

            <!-- Defense Button -->
            <Button
                android:id="@+id/btn_defense"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="🛡️ Bảo vệ"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_defense_background"
                android:layout_marginBottom="12dp"
                android:stateListAnimator="@null" />

            <!-- Heal Button -->
            <Button
                android:id="@+id/btn_heal"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="💚 Hồi máu"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_heal_background"
                android:layout_marginBottom="12dp"
                android:stateListAnimator="@null" />

            <!-- Speed Boost Button -->
            <Button
                android:id="@+id/btn_speed_boost"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="⚡ Tăng tốc"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_speed_background"
                android:layout_marginBottom="12dp"
                android:stateListAnimator="@null" />

            <!-- Special Attack Button -->
            <Button
                android:id="@+id/btn_special_attack"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="✨ Tấn công đặc biệt"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_special_background"
                android:layout_marginBottom="12dp"
                android:stateListAnimator="@null" />

            <!-- Settings Button -->
            <Button
                android:id="@+id/btn_settings"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="⚙️ Cài đặt"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_settings_background"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
